# 后端环境变量样例。复制为 backend/.env 后填入真实值（.env 已被 gitignore 忽略）。
# 本地开发：source backend/.env 后再启动 uvicorn。

# --- 服务 ---
APP_HOST=0.0.0.0
APP_PORT=8081
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Azure Speech（核心语音能力）---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus2

# --- LLM 后端选择（deepseek 或 azure；主后端异常自动 fallback）---
LLM_BACKEND=deepseek

# --- DeepSeek（默认 LLM 后端，OpenAI 兼容协议）---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Azure OpenAI（备用 LLM 后端，fallback 用）---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=
